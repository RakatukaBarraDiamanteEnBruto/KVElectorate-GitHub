import time
import ctypes
import numpy as np

from picosdk.ps2000 import ps2000 as ps
from picosdk.functions import adc2mV, assert_pico2000_ok


# ============================================================
# USER SETTINGS
# ============================================================
CAPTURE_DURATION_S = 10
SAMPLES_PER_BLOCK = 8000
TIMEBASE = 0  # fastest available timebase

# ps2000 constants
CHANNEL = ps.PS2000_CHANNEL["PS2000_CHANNEL_A"]
COUPLING_AC = False  # FALSE in ps2000_set_channel = AC coupling
CHANNEL_ENABLED = 1
OVERSAMPLE = 1

# NOTE:
# In ps2000, the smallest documented input range code is ±20 mV.
# The programmer's guide range table goes from ±20 mV to ±20 V,
# so there is no ±5 mV range in ps2000_set_channel. Use ±20 mV instead.
RANGE = ps.PS2000_VOLTAGE_RANGE["PS2000_2V"]

# Processing constants from your original script
DT = 0.00000001
MPC = 0.000012566370614
BS = 8.00823
VMEAN = -0.00117431640625  # kept because it exists in your file


# ============================================================
# HELPERS
# ============================================================
def pico_check(result, func_name="PicoSDK call"):
    """
    ps2000 functions usually return non-zero on success and 0 on failure.
    """
    if result == 0:
        raise RuntimeError(f"{func_name} failed")


# ============================================================
# OPEN PICO
# ============================================================
chandle = ps.ps2000_open_unit()
if chandle <= 0:
    raise RuntimeError(f"ps2000_open_unit failed, returned handle={chandle}")


# ============================================================
# CONFIGURE CHANNEL A
# AC coupling, nearest available range in ps2000 = ±20 mV
# ============================================================
status = {}

status["setChannelA"] = ps.ps2000_set_channel(
    chandle,
    CHANNEL,
    CHANNEL_ENABLED,
    COUPLING_AC,   # FALSE = AC coupling in ps2000
    RANGE
)
pico_check(status["setChannelA"], "ps2000_set_channel")


# ============================================================
# DISABLE TRIGGER
# source = PS2000_NONE
# ============================================================
status["setTrigger"] = ps.ps2000_set_trigger(
    chandle,
    ps.PS2000_CHANNEL["PS2000_NONE"],
    0,   # threshold
    0,   # direction
    0,   # delay
    0    # auto_trigger_ms
)
pico_check(status["setTrigger"], "ps2000_set_trigger")


# ============================================================
# CHECK TIMEBASE
# ============================================================
time_interval = ctypes.c_int32()
time_units = ctypes.c_int16()
returned_max_samples = ctypes.c_int32()

status["getTimebase"] = ps.ps2000_get_timebase(
    chandle,
    TIMEBASE,
    SAMPLES_PER_BLOCK,
    ctypes.byref(time_interval),
    ctypes.byref(time_units),
    OVERSAMPLE,
    ctypes.byref(returned_max_samples)
)
pico_check(status["getTimebase"], "ps2000_get_timebase")

print(f"Sample interval: {time_interval.value} (units code {time_units.value})")
print(f"Max samples available at this timebase: {returned_max_samples.value}")


# ============================================================
# CAPTURE STORAGE
# Each entry is one 1D np array of 8000 samples
# ============================================================
captured_blocks = []


# ============================================================
# CAPTURE ONE BLOCK
# ============================================================
def capture_block():
    buffer_a = (ctypes.c_int16 * SAMPLES_PER_BLOCK)()
    overflow = ctypes.c_int16()
    time_indisposed_ms = ctypes.c_int32()

    # In ps2000 block mode, run_block requests total no_of_samples.
    status["runBlock"] = ps.ps2000_run_block(
        chandle,
        SAMPLES_PER_BLOCK,
        TIMEBASE,
        OVERSAMPLE,
        ctypes.byref(time_indisposed_ms)
    )
    pico_check(status["runBlock"], "ps2000_run_block")

    # Poll until ready
    while True:
        ready = ps.ps2000_ready(chandle)
        if ready > 0:
            break
        if ready < 0:
            raise RuntimeError("ps2000_ready indicates device not attached")
        # small pause to avoid busy-spinning too hard
        time.sleep(0.001)

    sample_count = ps.ps2000_get_values(
        chandle,
        ctypes.byref(buffer_a),
        None,
        None,
        None,
        ctypes.byref(overflow),
        SAMPLES_PER_BLOCK
    )

    if sample_count <= 0:
        raise RuntimeError("ps2000_get_values failed or returned no samples")

    return np.array(buffer_a[:sample_count], dtype=np.int16)


# ============================================================
# PROCESS CAPTURED BLOCKS
# Output shape: (n_samples, 7, 8000)
#
# Index meaning:
#   0 = raw ADC
#   1 = shifted ADC (+49)
#   2 = voltage
#   3 = mean removed signal
#   4 = integrated signal
#   5 = divided by MPC
#   6 = multiplied by BS
# ============================================================
def process_captured_blocks(block_list, dt=DT, mpc=MPC, bs=BS):
    ns = len(block_list)

    if ns == 0:
        return np.empty((0, 7, SAMPLES_PER_BLOCK), dtype=np.float64)

    processed = np.zeros((ns, 7, SAMPLES_PER_BLOCK), dtype=np.float64)

    for i in range(ns):
        raw_block = np.asarray(block_list[i], dtype=np.float64)

        if raw_block.shape[0] != SAMPLES_PER_BLOCK:
            raise ValueError(
                f"Block {i} has length {raw_block.shape[0]}, "
                f"expected {SAMPLES_PER_BLOCK}"
            )

        # Row 0: raw ADC
        processed[i, 0, :] = raw_block

        # Row 1: shifted ADC
        processed[i, 1, :] = processed[i, 0, :] + 49

        # Row 2: voltage
        processed[i, 2, :] = processed[i, 1, :] * 10 / 256

        # Row 3: scaled signal then mean removed
        processed[i, 3, :] = processed[i, 2, :] * 5.5
        processed[i, 3, :] = processed[i, 3, :] - processed[i, 3, :].mean()

        # Row 4: trapezoidal integration
        processed[i, 4, 0] = 0.0
        processed[i, 4, 1:] = np.cumsum(
            0.5 * (processed[i, 3, :-1] + processed[i, 3, 1:]) * dt
        )

        # Row 5: divide by mpc
        processed[i, 5, :] = processed[i, 4, :] / mpc

        # Row 6: multiply by BS
        processed[i, 6, :] = processed[i, 5, :] * bs

    return processed


# ============================================================
# TIMED ACQUISITION LOOP
# Wait for each 1-second window using monotonic time
# ============================================================
start_time = time.monotonic()
end_time = start_time + CAPTURE_DURATION_S
next_read_time = start_time + 1.0

print("Starting timed block acquisition...")

while True:
    now = time.monotonic()

    if now >= end_time:
        break

    if now >= next_read_time:
        read_timestamp = now - start_time

        block = capture_block()
        captured_blocks.append(block)

        print(
            f"Read at t = {read_timestamp:.6f} s | "
            f"Captured block {len(captured_blocks)} | "
            f"shape = {block.shape}"
        )

        next_read_time += 1.0

        while next_read_time <= time.monotonic():
            next_read_time += 1.0


# ============================================================
# STOP AND CLOSE SCOPE
# ============================================================
status["stop"] = ps.ps2000_stop(chandle)
pico_check(status["stop"], "ps2000_stop")

status["closeUnit"] = ps.ps2000_close_unit(chandle)
pico_check(status["closeUnit"], "ps2000_close_unit")


# ============================================================
# PROCESS ALL CAPTURED BLOCKS AFTER ACQUISITION
# ============================================================
processed_blocks = process_captured_blocks(captured_blocks)

print("\nAcquisition finished.")
print(f"Total captured blocks: {len(captured_blocks)}")
print(f"Processed array shape: {processed_blocks.shape}")

if len(captured_blocks) > 0:
    print("\nExample first raw block shape:", captured_blocks[0].shape)
    print("Example first processed sample shape:", processed_blocks[0].shape)
    print("First processed sample, row 0 (raw ADC), first 10 values:")
    print(processed_blocks[0, 0, :10])
from gpiozero import Button
from time import sleep

# Setup
switchpin1 = 19  # GPIO pin connected to COM
switchpin2 = 26

switch1 = Button(switchpin1)
switch2 = Button(switchpin2)

while True:
    if switchpin1:  
        print("Switch 1 up")
    if switchpin2: 
        print("Switch 2 up")
    else:
        print("No switch up")




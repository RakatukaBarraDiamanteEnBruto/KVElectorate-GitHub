from gpiozero import Button
from time import sleep

# Setup
switchpin1 = 19  # GPIO pin connected to COM
switchpin2 = 26

switch1 = Button(switchpin1)
switch2 = Button(switchpin2)

while True:
    if switch1.is_pressed :  
        print("Switch 1 up")
    if switch2.is_pressed: 
        print("Switch 2 up")
    if switch1.is_pressed and switch2.is_pressed == False:
        print("No switch up")
    sleep(1)



